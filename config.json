{
  "notification_url": "http://localhost:8081/notify",
  "services": [
    {
      "name": "google",
      "action": {
        "type": "ping",
        "ping": {
          "host": "google.com"
        }
      }
    },
    {
      "name": "google_web",
      "action": {
        "type": "web_request",
        "web_request": {
          "url": "https://google.com",
          "method": "GET",
          "expected_status": 200
        }
      }
    },
    {
      "name": "local_web",
      "action": {
        "type": "web_request",
        "web_request": {
          "url": "http://localhost:8081/health",
          "method": "GET",
          "expected_status": 200
        }
      }
    },
    {
      "name": "bash_echo",
      "action": {
        "type": "bash_script",
        "bash_script": {
          "code": "echo 'hello world'",
          "expected_output_regexp": "hello"
        }
      }
    }
  ]
}
